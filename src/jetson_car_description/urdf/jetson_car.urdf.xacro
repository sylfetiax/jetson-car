<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="jetson_car">


  <!-- ===== Parameters ===== -->
  <xacro:property name="wheelbase" value="0.110"/>
  <xacro:property name="track_width" value="0.075"/>
  <xacro:property name="wheel_radius" value="0.015"/>
  <xacro:property name="wheel_width" value="0.010"/>
  <xacro:property name="chassis_length" value="0.160"/>
  <xacro:property name="chassis_width" value="0.086"/>
  <xacro:property name="chassis_height" value="0.026"/>
  <xacro:property name="max_steer" value="0.585"/>
  <xacro:property name="camera_x" value="0.104"/>
  <xacro:property name="camera_z" value="0.068"/>

  <xacro:property name="half_wheelbase" value="${wheelbase / 2}"/>
  <xacro:property name="half_track" value="${track_width / 2}"/>

  <!-- display.launch.py sets lock_drive_joints:=true so GUI only exposes steer sliders -->
  <xacro:arg name="lock_drive_joints" default="false"/>

  <!-- ===== Materials ===== -->
  <material name="blue"><color rgba="0.1 0.3 0.8 1.0"/></material>
  <material name="black"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>

  <!-- ===== Chassis ===== -->
  <!-- base_link: robot body center; z=0 is wheel axle height -->
  <link name="base_link">
    <visual>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>    <!-- lift box so bottom sits at z=0 -->
      <material name="blue"/>
    </visual>
    <collision>
      <geometry><box size="${chassis_length} ${chassis_width} ${chassis_height}"/></geometry>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>    <!-- lift box so bottom sits at z=0 -->
    </collision>
    <inertial>
      <mass value="1.5"/>
      <origin xyz="0 0 ${chassis_height/2}" rpy="0 0 0"/>    <!-- lift box so bottom sits at z=0 -->
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.02" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <!-- base_footprint: ground projection; standard root for navigation stacks -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>    <!-- lift body by one wheel radius -->
  </joint>

  <!-- ===== Wheel macro ===== -->
  <xacro:macro name="wheel_link" params="prefix">
    <link name="${prefix}_wheel">
      <visual>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>    <!-- rotate cylinder to roll along y -->
        <material name="black"/>
      </visual>
      <collision>
        <geometry><cylinder radius="${wheel_radius}" length="${wheel_width}"/></geometry>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>    <!-- rotate cylinder to roll along y -->
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
      </inertial>
    </link>
  </xacro:macro>

  <xacro:macro name="knuckle_link" params="prefix">
    <link name="${prefix}_knuckle">
      <inertial>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>
  </xacro:macro>

  <!-- Front: steer (z) on knuckle, roll (y) on wheel -->
  <xacro:macro name="front_wheel_assembly" params="prefix y_offset mimic_joint">
    <xacro:knuckle_link prefix="${prefix}"/>
    <xacro:wheel_link prefix="${prefix}"/>

    <joint name="${prefix}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${prefix}_knuckle"/>
      <origin xyz="${half_wheelbase} ${y_offset} 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>    <!-- steer about vertical z -->
      <limit lower="${-max_steer}" upper="${max_steer}" effort="10" velocity="5"/>
    </joint>

    <xacro:if value="$(arg lock_drive_joints)">
      <joint name="${prefix}_drive_joint" type="fixed">
        <parent link="${prefix}_knuckle"/>
        <child link="${prefix}_wheel"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
      </joint>
    </xacro:if>

    <xacro:unless value="$(arg lock_drive_joints)">
      <joint name="${prefix}_drive_joint" type="continuous">
        <parent link="${prefix}_knuckle"/>
        <child link="${prefix}_wheel"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>    <!-- roll about wheel axle (y) -->
        <mimic joint="${mimic_joint}" multiplier="1.0" offset="0.0"/>
      </joint>
    </xacro:unless>
  </xacro:macro>

  <xacro:front_wheel_assembly prefix="front_left" y_offset="${half_track}" mimic_joint="rear_left_drive_joint"/>
  <xacro:front_wheel_assembly prefix="front_right" y_offset="${-half_track}" mimic_joint="rear_right_drive_joint"/>

  <!-- Rear: roll only (no steer) -->
  <xacro:wheel_link prefix="rear_left"/>
  <xacro:wheel_link prefix="rear_right"/>

  <xacro:if value="$(arg lock_drive_joints)">
    <joint name="rear_left_drive_joint" type="fixed">
      <parent link="base_link"/>
      <child link="rear_left_wheel"/>
      <origin xyz="${-half_wheelbase} ${half_track} 0" rpy="0 0 0"/>
    </joint>

    <joint name="rear_right_drive_joint" type="fixed">
      <parent link="base_link"/>
      <child link="rear_right_wheel"/>
      <origin xyz="${-half_wheelbase} ${-half_track} 0" rpy="0 0 0"/>
    </joint>
  </xacro:if>

  <xacro:unless value="$(arg lock_drive_joints)">
    <joint name="rear_left_drive_joint" type="continuous">
      <parent link="base_link"/>
      <child link="rear_left_wheel"/>
      <origin xyz="${-half_wheelbase} ${half_track} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>    <!-- roll about wheel axle (y) -->
    </joint>

    <joint name="rear_right_drive_joint" type="continuous">
      <parent link="base_link"/>
      <child link="rear_right_wheel"/>
      <origin xyz="${-half_wheelbase} ${-half_track} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:unless>

  <!-- ===== Camera ===== -->
  <link name="camera_link">
    <visual>
      <geometry><box size="0.03 0.05 0.02"/></geometry>
      <material name="grey"/>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="${camera_x} 0 ${camera_z}" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <!-- ===== IMU ===== -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.04" rpy="0 0 0"/>
  </joint>

</robot>

